#simulated spectrum
set term pdf size 6,4
unset key
set output 'Cyclobutadiene.xyz.pdf'
set xrange [200:700]
set samples 10000
set xlabel 'Wavelength / nm' font ',18'
set ylabel 'Absorbance / Arbitrary Units' font ',18'
set xtics font ',18'
set ytics font ',18'
set bmargin 4
p 0.000*1/(1+((0inf-x)/(0.5*20.0*0inf*x))**2)+0.000*1/(1+((0inf-x)/(0.5*0.00022246941045606225*0inf*x))**2)+0.000*1/(1+((632.873-x)/(0.5*20.0*632.873*x))**2)\
