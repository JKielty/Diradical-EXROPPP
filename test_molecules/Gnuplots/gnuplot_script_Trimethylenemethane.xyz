#simulated spectrum
set term pdf size 6,4
unset key
set output 'Trimethylenemethane.xyz.pdf'
set xrange [200:700]
set samples 10000
set xlabel 'Wavelength / nm' font ',18'
set ylabel 'Absorbance / Arbitrary Units' font ',18'
set xtics font ',18'
set ytics font ',18'
set bmargin 4
p 0.000*1/(1+((1602.361-x)/(0.5*20.0*1602.361*x))**2)+0.000*1/(1+((1602.361-x)/(0.5*0.00022246941045606225*1602.361*x))**2)+0.000*1/(1+((1078.610-x)/(0.5*20.0*1078.610*x))**2)+0.000*1/(1+((1078.610-x)/(0.5*0.00022246941045606225*1078.610*x))**2)+0.034*1/(1+((298.787-x)/(0.5*20.0*298.787*x))**2)+0.034*1/(1+((298.787-x)/(0.5*0.00022246941045606225*298.787*x))**2)+0.026*1/(1+((286.960-x)/(0.5*20.0*286.960*x))**2)+0.026*1/(1+((286.960-x)/(0.5*0.00022246941045606225*286.960*x))**2)+0.000*1/(1+((276.768-x)/(0.5*20.0*276.768*x))**2)+0.000*1/(1+((276.768-x)/(0.5*0.00022246941045606225*276.768*x))**2)+0.497*1/(1+((190.565-x)/(0.5*20.0*190.565*x))**2)+0.497*1/(1+((190.565-x)/(0.5*0.00022246941045606225*190.565*x))**2)+0.520*1/(1+((189.671-x)/(0.5*20.0*189.671*x))**2)+0.520*1/(1+((189.671-x)/(0.5*0.00022246941045606225*189.671*x))**2)+0.000*1/(1+((172.165-x)/(0.5*20.0*172.165*x))**2)+0.000*1/(1+((172.165-x)/(0.5*0.00022246941045606225*172.165*x))**2)+0.000*1/(1+((170.333-x)/(0.5*20.0*170.333*x))**2)+0.000*1/(1+((170.333-x)/(0.5*0.00022246941045606225*170.333*x))**2)+0.000*1/(1+((144.398-x)/(0.5*20.0*144.398*x))**2)+0.000*1/(1+((144.398-x)/(0.5*0.00022246941045606225*144.398*x))**2)+0.000*1/(1+((144.027-x)/(0.5*20.0*144.027*x))**2)+0.000*1/(1+((144.027-x)/(0.5*0.00022246941045606225*144.027*x))**2) lw 3 dt 1